<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Version is overridden at build time via -d Version=x.y.z
       Default value below mirrors the current csproj version. -->
  <?define Version = "5.7.1" ?>
  <?define PublishDir = "..\publish\Release" ?>

  <Package Name="CenterHub"
           Manufacturer="CenterHub"
           Version="$(var.Version)"
           UpgradeCode="E8F3D2A1-5B7C-4E9F-A1D3-8C2B6F4E7A9D"
           Scope="perUser">

    <!-- Replace any older installation automatically when running this MSI -->
    <MajorUpgrade
        Schedule="afterInstallInitialize"
        DowngradeErrorMessage="A newer version of [ProductName] is already installed."
        AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <!-- ===== Install location ===== -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="CenterHub" />
    </StandardDirectory>

    <!-- ===== Start menu folder ===== -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="CenterHub">
        <Component Id="StartMenuFolderComponent" Guid="F6A7B8C9-D0E1-2345-F012-678901234567">
          <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\CenterHub" Name="StartMenuInstalled"
                         Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- ===== Desktop shortcut folder ===== -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- ===== Files: auto-harvest the entire publish directory ===== -->
    <!-- The Files element scans the publish output and generates one Component per file.
         Add new dependencies?  Re-publish and rebuild the MSI â€” no manifest edits needed. -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**">
        <!-- Skip debug symbols and XML doc files to keep the MSI lean -->
        <Exclude Files="$(var.PublishDir)\**\*.pdb" />
        <Exclude Files="$(var.PublishDir)\**\*.xml" />
      </Files>
    </ComponentGroup>

    <!-- ===== Shortcuts ===== -->
    <Component Id="AppShortcuts" Directory="ApplicationProgramsFolder"
               Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234560001">
      <Shortcut Id="StartMenuShortcut"
                Name="CenterHub"
                Description="System monitoring, audio control, and productivity tools"
                Target="[INSTALLFOLDER]CenterHubNew.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="CenterHub"
                Description="System monitoring, audio control, and productivity tools"
                Target="[INSTALLFOLDER]CenterHubNew.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppShortcutsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\CenterHub" Name="ShortcutsInstalled"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- ===== Feature tree ===== -->
    <Feature Id="ProductFeature" Title="CenterHub" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="StartMenuFolderComponent" />
      <ComponentRef Id="AppShortcuts" />
    </Feature>

    <!-- ===== Launch the app automatically when install/upgrade finishes ===== -->
    <!-- Covers both a fresh install (double-click MSI) and the in-app updater,
         which exits and hands off to msiexec — this relaunches the new version.
         Type 50 EXE-from-property action; impersonated so it runs in the user's
         session, async so msiexec doesn't wait on it. Skipped on uninstall. -->
    <SetProperty Id="LaunchTarget"
                 Value="[INSTALLFOLDER]CenterHubNew.exe"
                 Before="LaunchApplication"
                 Sequence="execute" />
    <CustomAction Id="LaunchApplication"
                  Property="LaunchTarget"
                  ExeCommand=""
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- ===== App metadata in Add/Remove Programs ===== -->
    <Icon Id="AppIcon.ico" SourceFile="..\Images\circular_connection_icon_155652.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/MikWil/CenterHubPC" />
    <Property Id="ARPHELPLINK"     Value="https://github.com/MikWil/CenterHubPC/issues" />
    <Property Id="ARPNOREPAIR"     Value="1" />
    <Property Id="ARPNOMODIFY"     Value="1" />

  </Package>
</Wix>
