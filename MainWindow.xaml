<Window x:Class="CenterHubNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"         
        xmlns:local="clr-namespace:CenterHubNew"
        xmlns:view="clr-namespace:CenterHubNew.MVVM.View"
        xmlns:viewmodel ="clr-namespace:CenterHubNew.MVVM.ViewModel"
        mc:Ignorable="d"
        Height="900" Width="1400"
        MinHeight="500" MinWidth="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Reusable Nav Tab Style: Use Tag for icon emoji, Content for label text -->
        <Style x:Key="NavTabStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="NavTabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="8,10"
                                Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="NavIcon" Text="{TemplateBinding Tag}" FontSize="16" VerticalAlignment="Center" MinWidth="20" TextAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                                <TextBlock x:Name="NavText" 
                                           Text="{TemplateBinding Content}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="NavText" Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
                                <Setter TargetName="NavIcon" Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource CardInnerBrush}"/>
                                <Setter TargetName="NavText" Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Nav Section Header Style -->
        <Style x:Key="NavSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="8,16,0,8"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="30" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Resize Grips - Transparent borders for resizing from all sides -->
            <!-- Top edge -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Top"
                    Height="4"
                    Cursor="SizeNS"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1000"/>
            <!-- Bottom edge -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Bottom"
                    Height="4"
                    Cursor="SizeNS"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1000"/>
            <!-- Left edge -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Stretch"
                    Width="4"
                    Cursor="SizeWE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1000"/>
            <!-- Right edge -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Stretch"
                    Width="4"
                    Cursor="SizeWE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1000"/>
            <!-- Top-left corner -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Width="8" 
                    Height="8"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1001"/>
            <!-- Top-right corner -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Width="8" 
                    Height="8"
                    Cursor="SizeNESW"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1001"/>
            <!-- Bottom-left corner -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Bottom"
                    Width="8" 
                    Height="8"
                    Cursor="SizeNESW"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1001"/>
            <!-- Bottom-right corner -->
            <Border Background="Transparent" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Width="8" 
                    Height="8"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    Panel.ZIndex="1001"/>

            <!-- Modern Title Bar -->
            <Border Grid.Row="0" 
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    MouseDown="Border_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- App Title -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                Margin="24,16">
                        <TextBlock Text="🚀" FontSize="20" Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}"/>
                        <TextBlock Text="CenterHub" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AppVersion}" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,8,0">
                        <Button Width="46"
                                Height="32"
                                Content="─"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource CardInnerBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentLightBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area with Navigation -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="{Binding SidebarWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Navigation Sidebar -->
                <Border Grid.Column="0" 
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        MouseDown="Border_MouseDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                    <StackPanel Grid.Row="0" Margin="4,16,4,24">
                        
                        <!-- ═══ DASHBOARD ═══ -->
                        <TextBlock Text="DASHBOARD" Style="{StaticResource NavSectionHeader}" Margin="8,0,0,8"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <RadioButton Tag="📊" Content="Monitoring" IsChecked="{Binding IsMonitoringSelected}" Command="{Binding MonitoringViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        
                        <!-- ═══ PRODUCTIVITY ═══ -->
                        <TextBlock Text="PRODUCTIVITY" Style="{StaticResource NavSectionHeader}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <RadioButton Tag="🧍" Content="Standing" IsChecked="{Binding IsStandingSelected}" Command="{Binding StandingViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        <RadioButton Tag="📝" Content="Notes" IsChecked="{Binding IsNotesSelected}" Command="{Binding NotesViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        
                        <!-- ═══ MEDIA ═══ -->
                        <TextBlock Text="MEDIA" Style="{StaticResource NavSectionHeader}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <RadioButton Tag="🎵" Content="Sound" IsChecked="{Binding IsSoundSelected}" Command="{Binding SoundViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        <RadioButton Tag="🔊" Content="Soundboard" IsChecked="{Binding IsSoundboardSelected}" Command="{Binding SoundboardViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        
                        <!-- ═══ TOOLS ═══ -->
                        <TextBlock Text="TOOLS" Style="{StaticResource NavSectionHeader}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <RadioButton Tag="🛠️" Content="Utilities" IsChecked="{Binding IsUtilitiesSelected}" Command="{Binding UtilitiesViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        <RadioButton Tag="🤖" Content="Auto Clicker" IsChecked="{Binding IsAutoClickerSelected}" Command="{Binding AutoClickerViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        <RadioButton Tag="📋" Content="Clipboard" IsChecked="{Binding IsClipboardSelected}" Command="{Binding ClipboardViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        
                        <!-- ═══ SETTINGS ═══ -->
                        <TextBlock Text="SETTINGS" Style="{StaticResource NavSectionHeader}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <RadioButton Tag="⌨️" Content="Hotkeys" IsChecked="{Binding IsHotkeySettingsSelected}" Command="{Binding HotkeySettingsViewCommand}" Style="{StaticResource NavTabStyle}"/>
                        
                    </StackPanel>
                        
                        <!-- Collapse/Expand Button -->
                        <Button Grid.Row="1" 
                                Command="{Binding ToggleSidebarCommand}"
                                Cursor="Hand"
                                Margin="4,0,4,16">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="8,8">
                                                    <TextBlock Text="{Binding SidebarToggleIcon}" 
                                                               FontSize="14" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource CardInnerBrush}"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
                
                <!-- Content Area -->
                <Grid Grid.Column="1" MouseDown="ContentArea_MouseDown">
                    <ContentControl Content="{Binding CurrentView}" Margin="0"/>
                    
                    <!-- Toast Container -->
                    <view:ToastContainer HorizontalAlignment="Right" 
                                         VerticalAlignment="Top" 
                                         Margin="0,20,20,0"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
