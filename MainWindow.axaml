<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:view="clr-namespace:CenterHubNew.MVVM.View"
        xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel"
        x:Class="CenterHubNew.MainWindow"
        x:DataType="viewmodel:MainViewModel"
        mc:Ignorable="d"
        Height="880" Width="1360"
        MinHeight="500" MinWidth="820"
        SystemDecorations="None"
        TransparencyLevelHint="Mica,AcrylicBlur"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

    <Border Background="{StaticResource BackgroundDarkBrush}"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderHairline}"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBackgroundBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderHairline}"
                    CornerRadius="8,8,0,0"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto" Height="46">

                    <!-- App identity -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0"
                                Spacing="10">
                        <!-- Dot logo -->
                        <Border Width="22" Height="22" CornerRadius="11"
                                Background="{StaticResource AccentBrush}"
                                VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource TextOnAccentBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="CenterHub"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Spacing="2">
                        <Button Classes="chrome"
                                FontSize="14"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="FavoritesButton_Click"
                                ToolTip.Tip="Favorites Panel">
                            <TextBlock Text="&#x2605;" FontSize="14"/>
                        </Button>
                        <Button Classes="chrome"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="MinimizeButton_Click"
                                ToolTip.Tip="Minimize to tray">
                            <TextBlock Text="&#x2212;" FontSize="16" FontWeight="Bold"/>
                        </Button>
                        <Button Classes="chrome close"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="CloseButton_Click"
                                ToolTip.Tip="Close">
                            <TextBlock Text="&#xD7;" FontSize="16" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== UPDATE BANNER ===== -->
            <Border Grid.Row="1"
                    Background="{StaticResource AccentSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource AccentBrush}"
                    Padding="20,10"
                    IsVisible="{Binding IsUpdateAvailable}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">

                    <!-- Status icon -->
                    <Border Grid.Column="0" Grid.RowSpan="2"
                            Width="34" Height="34" CornerRadius="10"
                            Background="{StaticResource AccentBrush}"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="&#xE895;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                   FontSize="17"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextOnAccentBrush}"/>
                    </Border>

                    <!-- Headline + body preview -->
                    <StackPanel Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Update available —"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UpdateHeadline}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentHoverBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UpdateBodyPreview}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="700"
                                   HorizontalAlignment="Left"
                                   Margin="0,2,0,0"
                                   IsVisible="{Binding !IsDownloadingUpdate}"/>
                        <ProgressBar Value="{Binding DownloadProgressPercent}"
                                     Maximum="100"
                                     Height="4"
                                     MinWidth="240"
                                     HorizontalAlignment="Left"
                                     Margin="0,6,0,0"
                                     Foreground="{StaticResource AccentBrush}"
                                     IsVisible="{Binding IsDownloadingUpdate}"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2" Grid.RowSpan="2" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <Button Classes="primary" Padding="14,7" FontSize="12"
                                Content="{Binding UpdateActionText}"
                                Command="{Binding DownloadAndInstallUpdateCommand}"
                                IsEnabled="{Binding !IsDownloadingUpdate}"/>
                        <Button Classes="secondary" Padding="12,7" FontSize="12"
                                Content="Skip this version"
                                ToolTip.Tip="Don't show this version again — wait for the next one"
                                Command="{Binding SkipUpdateCommand}"
                                IsEnabled="{Binding !IsDownloadingUpdate}"/>
                    </StackPanel>

                    <Button Grid.Column="3" Grid.RowSpan="2"
                            Classes="ghost" Padding="8,7"
                            VerticalAlignment="Center" Margin="4,0,0,0"
                            ToolTip.Tip="Hide until next launch"
                            Command="{Binding DismissUpdateCommand}"
                            IsEnabled="{Binding !IsDownloadingUpdate}">
                        <TextBlock Text="&#xE894;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== MAIN LAYOUT: sidebar + content ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SidebarWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBackgroundBrush}"
                        BorderThickness="0,0,1,0"
                        BorderBrush="{StaticResource BorderHairline}">
                    <Grid RowDefinitions="*,Auto">

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Hidden"
                                      Padding="0,12,0,0">
                            <StackPanel>

                                <!-- DASHBOARD -->
                                <TextBlock Text="DASHBOARD"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="18,0,0,6"
                                           IsVisible="{Binding IsSidebarExpanded}"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xEC4A;"
                                             Content="Monitoring"
                                             ToolTip.Tip="Real-time hardware monitoring"
                                             IsChecked="{Binding IsMonitoringSelected}"
                                             Command="{Binding MonitoringViewCommand}"
                                             GroupName="Nav"/>

                                <!-- PRODUCTIVITY -->
                                <TextBlock Text="PRODUCTIVITY"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="18,16,0,6"
                                           IsVisible="{Binding IsSidebarExpanded}"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE916;"
                                             Content="Standing"
                                             ToolTip.Tip="Sit/Stand timer"
                                             IsChecked="{Binding IsStandingSelected}"
                                             Command="{Binding StandingViewCommand}"
                                             GroupName="Nav"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE70B;"
                                             Content="Notes"
                                             ToolTip.Tip="Quick notes"
                                             IsChecked="{Binding IsNotesSelected}"
                                             Command="{Binding NotesViewCommand}"
                                             GroupName="Nav"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE737;"
                                             Content="Layouts"
                                             ToolTip.Tip="Save and restore window arrangements"
                                             IsChecked="{Binding IsLayoutsSelected}"
                                             Command="{Binding LayoutsViewCommand}"
                                             GroupName="Nav"/>

                                <!-- MEDIA -->
                                <TextBlock Text="MEDIA"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="18,16,0,6"
                                           IsVisible="{Binding IsSidebarExpanded}"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE767;"
                                             Content="Sound"
                                             ToolTip.Tip="Audio profiles and devices"
                                             IsChecked="{Binding IsSoundSelected}"
                                             Command="{Binding SoundViewCommand}"
                                             GroupName="Nav"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE955;"
                                             Content="Soundboard"
                                             ToolTip.Tip="Trigger sound clips"
                                             IsChecked="{Binding IsSoundboardSelected}"
                                             Command="{Binding SoundboardViewCommand}"
                                             GroupName="Nav"/>

                                <!-- TOOLS -->
                                <TextBlock Text="TOOLS"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="18,16,0,6"
                                           IsVisible="{Binding IsSidebarExpanded}"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xEC7A;"
                                             Content="Utilities"
                                             ToolTip.Tip="Encoders, converters, generators"
                                             IsChecked="{Binding IsUtilitiesSelected}"
                                             Command="{Binding UtilitiesViewCommand}"
                                             GroupName="Nav"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xF272;"
                                             Content="Auto Clicker"
                                             ToolTip.Tip="Automated mouse clicks"
                                             IsChecked="{Binding IsAutoClickerSelected}"
                                             Command="{Binding AutoClickerViewCommand}"
                                             GroupName="Nav"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xF0E3;"
                                             Content="Clipboard"
                                             ToolTip.Tip="Clipboard history"
                                             IsChecked="{Binding IsClipboardSelected}"
                                             Command="{Binding ClipboardViewCommand}"
                                             GroupName="Nav"/>

                                <!-- SYSTEM -->
                                <TextBlock Text="SYSTEM"
                                           FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="18,16,0,6"
                                           IsVisible="{Binding IsSidebarExpanded}"/>
                                <RadioButton Classes="navtab"
                                             Tag="&#xE92E;"
                                             Content="Hotkeys"
                                             ToolTip.Tip="Global keyboard shortcuts"
                                             IsChecked="{Binding IsHotkeySettingsSelected}"
                                             Command="{Binding HotkeySettingsViewCommand}"
                                             GroupName="Nav"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Collapse / expand button -->
                        <Button Grid.Row="1"
                                Command="{Binding ToggleSidebarCommand}"
                                Cursor="Hand"
                                Margin="8,0,8,16"
                                Classes="secondary"
                                Padding="8,7"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <TextBlock Text="{Binding SidebarToggleIcon}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- CONTENT AREA (Mica shows through) -->
                <Grid Grid.Column="1" Background="Transparent">
                    <ContentControl Content="{Binding CurrentView}"/>
                    <view:ToastContainer HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,16,16,0"/>
                </Grid>
            </Grid>

            <!-- ===== EXIT CONFIRMATION OVERLAY ===== -->
            <Border x:Name="ExitOverlay"
                    Grid.RowSpan="3"
                    Background="#A8000000"
                    IsVisible="False"
                    ZIndex="1000">
                <Border Width="420"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource BorderHairline}"
                        CornerRadius="12"
                        Padding="28,24"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BoxShadow="0 12 40 0 #80000000">
                    <StackPanel Spacing="0">
                        <!-- Icon + title -->
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="{StaticResource ErrorSubtleBrush}"
                                    BorderThickness="1" BorderBrush="{StaticResource ErrorBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="!" FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource ErrorBrush}"/>
                            </Border>
                            <TextBlock Text="Exit CenterHub?"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            <Run Text="This will stop all running services — hotkeys, auto-clicker, standing timer, and clipboard monitor."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,22">
                            <Run Text="Tip: use the minimize button if you just want to hide the window — CenterHub will keep running in the system tray."/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel" Classes="secondary"
                                    Padding="22,10"
                                    Click="CancelExit_Click"/>
                            <Button Content="Exit" Classes="danger"
                                    Padding="22,10"
                                    Click="ConfirmExit_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</Window>
