{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Application": {
    "Name": "CenterHub",
    "Version": "3.0.0",
    "StartMinimized": false,
    "ShowInSystemTray": true,
    "AutoStart": true
  },
  "SystemMonitor": {
    "UpdateInterval": 2000,
    "EnableCpuMonitoring": true,
    "EnableGpuMonitoring": true,
    "EnableTemperatureMonitoring": true
  },
  "Sound": {
    "DefaultDeviceRefreshInterval": 5000,
    "RememberLastUsedDevice": true
  },
  "Clicker": {
    "DefaultClicksPerSecond": 1,
    "MaxClicksPerSecond": 100
  },
  "FileMove": {
    "DefaultSourcePath": "",
    "DefaultDestinationPath": "",
    "RememberPaths": true
  }
}
