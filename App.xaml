<Application x:Class="CenterHubNew.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CenterHubNew"             
             xmlns:viewmodel ="clr-namespace:CenterHubNew.MVVM.ViewModel"
             xmlns:view ="clr-namespace:CenterHubNew.MVVM.View"
             xmlns:converters="clr-namespace:CenterHubNew.MVVM.Converters"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Indigo.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Slider.xaml" />
                <ResourceDictionary Source="Theme/MenuButtonTheme.xaml"/>
                <ResourceDictionary Source="Theme/TextBoxTheme.xaml"/>
                <ResourceDictionary Source="Theme/ModernWideTextBoxTheme.xaml"/>
                <ResourceDictionary Source="Theme/SearchTextBoxTheme.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
           
            <!-- Global text rendering settings for crisp text -->
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>
            <Style TargetType="{x:Type Control}">
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>
           
            <DataTemplate DataType="{x:Type viewmodel:HomeViewModel}">
                <view:HomeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:SoundViewModel}">
                <view:SoundView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:StandingViewModel}">
                <view:StandingView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:MoveFilesViewModel}">
                <view:MoveFilesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:MonitoringViewModel}">
                <view:MonitoringView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:UtilitiesViewModel}">
                <view:UtilitiesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodel:QuickNotesViewModel}">
                <view:NotesView/>
            </DataTemplate>
            
            <!-- Converters -->
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:NotNullConverter x:Key="NotNullConverter"/>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
