<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel"
             x:Class="CenterHubNew.MVVM.View.NotesView"
             x:DataType="viewmodel:QuickNotesViewModel"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="24,20" ColumnDefinitions="260,*">

        <!-- LEFT: Notes List -->
        <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
            <Grid RowDefinitions="Auto,Auto,*">

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Notes"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Quick personal notes"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Row="1" Content="+ New Note" Classes="primary"
                        Command="{Binding CreateNoteCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14" Padding="12,9"/>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Notes}"
                         SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardInnerBrush}"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,5">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   FontSize="13" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ModifiedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"
                                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="ghost" Padding="6,4"
                                            ToolTip.Tip="Delete note"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xD7;" FontSize="14"
                                                   Foreground="{StaticResource ErrorBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding"     Value="0"/>
                            <Setter Property="Background"  Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected > Border">
                            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
                            <Setter Property="BorderThickness"  Value="1"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </Grid>
        </Border>

        <!-- RIGHT: Note Editor -->
        <Border Grid.Column="1" Classes="card" Margin="10,0,0,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Editor"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Title -->
                <Border Grid.Row="1" Background="{StaticResource CardInnerBrush}"
                        CornerRadius="8" Padding="2" Margin="0,0,0,10">
                    <TextBox Text="{Binding CurrentTitle, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="15" FontWeight="SemiBold"
                             Padding="12,9"
                             Watermark="Note title..."/>
                </Border>

                <!-- Content -->
                <Border Grid.Row="2" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="4">
                    <TextBox Text="{Binding CurrentContent, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Padding="12"
                             VerticalContentAlignment="Top"/>
                </Border>

                <!-- Actions -->
                <Grid Grid.Row="3" Margin="0,12,0,0" ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Classes="primary" Padding="22,9"
                            Command="{Binding SaveCurrentNoteCommand}"
                            Content="Save"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedNote.ModifiedAt, StringFormat='Last saved: {0:MMM dd, yyyy HH:mm}'}"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Export" Classes="secondary"
                            Padding="16,9" Click="ExportBtn_Click"
                            ToolTip.Tip="Export as text file"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
