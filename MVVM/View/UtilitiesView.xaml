<UserControl x:Class="CenterHubNew.MVVM.View.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:UtilitiesViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="20,16" Background="Transparent">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="🛠️" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                <TextBlock Text="Utilities" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            
            <!-- ═══ SHUTDOWN TIMER ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="SHUTDOWN TIMER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⏻" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="Date" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ComputerViewModel.SelectedDateText, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource InputTextBox}" Width="120"/>
                            <TextBlock Text="Time" VerticalAlignment="Center" FontSize="12" Margin="16,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ComputerViewModel.SelectedTime}" 
                                     Style="{StaticResource InputTextBox}" Width="80"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Schedule" Style="{StaticResource PrimaryButton}" Padding="20,8"
                                    Command="{Binding ComputerViewModel.ScheduleShutdownCommand}" Margin="0,0,8,0"/>
                            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Padding="20,8"
                                    Command="{Binding ComputerViewModel.CancelShutdownCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ FILE MANAGER ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="FILE MANAGER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0" Margin="0,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding MoveFilesViewModel.SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}"/>
                            <Button Grid.Column="1" Content="..." Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="8,0"
                                    Command="{Binding MoveFilesViewModel.BrowseSourceCommand}"/>
                            <TextBlock Grid.Column="2" Text="▶" FontSize="12" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource AccentBrush}"/>
                            <TextBox Grid.Column="3" Text="{Binding MoveFilesViewModel.TargetLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}"/>
                            <Button Grid.Column="4" Content="..." Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="8,0,0,0"
                                    Command="{Binding MoveFilesViewModel.BrowseTargetCommand}"/>
                        </Grid>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <CheckBox Content="Copy" IsChecked="{Binding MoveFilesViewModel.IsCopy}"
                                      Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="Move" Style="{StaticResource PrimaryButton}" Padding="24,8"
                                    Command="{Binding MoveFilesViewModel.MoveFilesCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ JSON STRINGIFY ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="JSON STRINGIFY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding JsonStringifyViewModel.InputJson, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 MinHeight="70" MaxHeight="160" VerticalContentAlignment="Top"
                                 Padding="8,6" FontFamily="Consolas"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0">
                            <Button Content="Paste" Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,0,4"
                                    Command="{Binding JsonStringifyViewModel.PasteFromClipboardCommand}"/>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Padding="12,6"
                                    Command="{Binding JsonStringifyViewModel.ClearCommand}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding JsonStringifyViewModel.ErrorMessage}" 
                               Foreground="{StaticResource ErrorBrush}" FontSize="11" Margin="0,0,0,4"
                               Visibility="{Binding JsonStringifyViewModel.HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                               TextWrapping="Wrap"/>
                    <Button Content="Stringify" Style="{StaticResource PrimaryButton}" Padding="20,7"
                            HorizontalAlignment="Left" Margin="0,4,0,10"
                            Command="{Binding JsonStringifyViewModel.StringifyCommand}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding JsonStringifyViewModel.OutputJson, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 MinHeight="50" MaxHeight="160" VerticalContentAlignment="Top"
                                 Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource PrimaryButton}" Padding="12,6"
                                VerticalAlignment="Top" Margin="8,0,0,0"
                                Command="{Binding JsonStringifyViewModel.CopyOutputCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ BASE64 ENCODE / DECODE ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="BASE64 ENCODE / DECODE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding ConverterToolsViewModel.Base64Input, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="50" MaxHeight="120" VerticalContentAlignment="Top"
                             Padding="8,6" FontFamily="Consolas" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Encode" Style="{StaticResource PrimaryButton}" Padding="20,7" Margin="0,0,6,0"
                                Command="{Binding ConverterToolsViewModel.Base64EncodeCommand}"/>
                        <Button Content="Decode" Style="{StaticResource SecondaryButton}" Padding="20,7"
                                Command="{Binding ConverterToolsViewModel.Base64DecodeCommand}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.Base64Output, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="120"
                                 VerticalContentAlignment="Top" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource PrimaryButton}" Padding="12,6"
                                VerticalAlignment="Top" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyBase64OutputCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ URL ENCODE / DECODE ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="URL ENCODE / DECODE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding ConverterToolsViewModel.UrlInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="40" MaxHeight="100" VerticalContentAlignment="Top"
                             Padding="8,6" FontFamily="Consolas" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Encode" Style="{StaticResource PrimaryButton}" Padding="20,7" Margin="0,0,6,0"
                                Command="{Binding ConverterToolsViewModel.UrlEncodeCommand}"/>
                        <Button Content="Decode" Style="{StaticResource SecondaryButton}" Padding="20,7"
                                Command="{Binding ConverterToolsViewModel.UrlDecodeCommand}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.UrlOutput, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="100"
                                 VerticalContentAlignment="Top" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource PrimaryButton}" Padding="12,6"
                                VerticalAlignment="Top" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyUrlOutputCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ HASH GENERATOR ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="HASH GENERATOR" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.HashInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Generate" Style="{StaticResource PrimaryButton}" Padding="20,7" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.GenerateHashesCommand}"/>
                    </Grid>
                    <!-- MD5 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MD5" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ConverterToolsViewModel.HashMd5, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True" Padding="8,5" FontFamily="Consolas" FontSize="11"/>
                        <Button Grid.Column="2" Content="Copy" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="10" Margin="6,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyHashMd5Command}"/>
                    </Grid>
                    <!-- SHA-256 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SHA256" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ConverterToolsViewModel.HashSha256, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True" Padding="8,5" FontFamily="Consolas" FontSize="11"/>
                        <Button Grid.Column="2" Content="Copy" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="10" Margin="6,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyHashSha256Command}"/>
                    </Grid>
                    <!-- SHA-512 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SHA512" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ConverterToolsViewModel.HashSha512, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True" Padding="8,5" FontFamily="Consolas" FontSize="11"/>
                        <Button Grid.Column="2" Content="Copy" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="10" Margin="6,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyHashSha512Command}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ UNIX TIMESTAMP ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="UNIX TIMESTAMP" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.EpochInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="To Date" Style="{StaticResource PrimaryButton}" Padding="16,7" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.EpochToDateCommand}"/>
                        <Button Grid.Column="2" Content="Now" Style="{StaticResource SecondaryButton}" Padding="16,7" Margin="6,0,0,0"
                                Command="{Binding ConverterToolsViewModel.DateToEpochCommand}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.EpochOutput, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource PrimaryButton}" Padding="12,6"
                                VerticalAlignment="Top" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyEpochOutputCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══ GUID GENERATOR ═══ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="GUID / UUID GENERATOR" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ConverterToolsViewModel.GeneratedGuid, Mode=OneWay}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True" Padding="8,6" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource PrimaryButton}" Padding="12,6" Margin="8,0,0,0"
                                Command="{Binding ConverterToolsViewModel.CopyGuidCommand}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="New GUID" Style="{StaticResource PrimaryButton}" Padding="16,7" Margin="0,0,6,0"
                                Command="{Binding ConverterToolsViewModel.GenerateNewGuidCommand}"/>
                        <Button Content="UPPERCASE" Style="{StaticResource SecondaryButton}" Padding="14,7" Margin="0,0,6,0"
                                Command="{Binding ConverterToolsViewModel.GenerateNewGuidUpperCaseCommand}"/>
                        <Button Content="No Dashes" Style="{StaticResource SecondaryButton}" Padding="14,7"
                                Command="{Binding ConverterToolsViewModel.GenerateNewGuidNoDashesCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
