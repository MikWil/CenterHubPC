<UserControl x:Class="CenterHubNew.MVVM.View.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:UtilitiesViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <local:BoolToMonitoringTextConverter x:Key="BoolToMonitoringTextConverter"/>
        <local:BoolToPinBorderConverter x:Key="BoolToPinBorderConverter"/>
        <local:BoolToRunningTextConverter x:Key="BoolToRunningTextConverter"/>
        <local:BoolToRunningBrushConverter x:Key="BoolToRunningBrushConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="24,20" Background="Transparent">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🛠️" FontSize="22" Margin="0,0,10,0" Foreground="{StaticResource AccentLightBrush}"/>
                <TextBlock Text="Utilities" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <!-- SOUND SECTION -->
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <ToggleButton x:Name="SoundToggle" IsChecked="True" Style="{StaticResource SectionToggle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎵" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="Sound" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <StackPanel Visibility="{Binding IsChecked, ElementName=SoundToggle, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,12,0,0">
                        <!-- Profiles Row -->
                        <TextBlock Text="PROFILES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Profile 1 -->
                            <Border Grid.Column="0" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBox Text="{Binding SoundViewModel.Profile1.Name, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                             Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile1.AudioDevice, TargetNullValue='No device'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile1.Volume, StringFormat='Vol: {0:P0}'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Apply" Command="{Binding SoundViewModel.ApplyProfileCommand}" CommandParameter="0"
                                                Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                        <Button Content="Save" Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" CommandParameter="0"
                                                Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Profile 2 -->
                            <Border Grid.Column="1" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="10" Margin="3,0">
                                <StackPanel>
                                    <TextBox Text="{Binding SoundViewModel.Profile2.Name, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                             Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile2.AudioDevice, TargetNullValue='No device'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile2.Volume, StringFormat='Vol: {0:P0}'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Apply" Command="{Binding SoundViewModel.ApplyProfileCommand}" CommandParameter="1"
                                                Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                        <Button Content="Save" Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" CommandParameter="1"
                                                Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Profile 3 -->
                            <Border Grid.Column="2" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="10" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBox Text="{Binding SoundViewModel.Profile3.Name, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                             Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile3.AudioDevice, TargetNullValue='No device'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SoundViewModel.Profile3.Volume, StringFormat='Vol: {0:P0}'}" 
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Apply" Command="{Binding SoundViewModel.ApplyProfileCommand}" CommandParameter="2"
                                                Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                        <Button Content="Save" Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" CommandParameter="2"
                                                Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- Quick Controls -->
                        <TextBlock Text="QUICK CONTROLS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Mic -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🎤" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                                <Button Content="{Binding SoundViewModel.MicrophoneMuteButtonText}" 
                                        Command="{Binding SoundViewModel.ToggleMicrophoneMuteCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                            </StackPanel>
                            
                            <!-- Volume -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding SoundViewModel.OutputVolume, Mode=TwoWay}" 
                                        Width="120" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SoundViewModel.OutputVolume, StringFormat='{}{0:P0}'}" 
                                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="35" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <!-- Output -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox ItemsSource="{Binding SoundViewModel.ActiveSoundSource}"
                                          SelectedItem="{Binding SoundViewModel.SelectedSoundSource}"
                                          Width="180" Style="{StaticResource DropdownStyle}"/>
                                <Button Content="Audio" Style="{StaticResource PrimaryButton}" Padding="10,6" Margin="6,0,0,0"
                                        Command="{Binding SoundViewModel.SetDefaultPlaybackDeviceCommand}"/>
                                <Button Content="Comm" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="4,0,0,0"
                                        Command="{Binding SoundViewModel.SetDefaultCommunicationDeviceCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <!-- TOOLS SECTION -->
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <ToggleButton x:Name="ToolsToggle" IsChecked="True" Style="{StaticResource SectionToggle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="Tools" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <StackPanel Visibility="{Binding IsChecked, ElementName=ToolsToggle, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,16,0,0">
                        
                        <!-- Standing Timer - Full Width -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🧍" FontSize="16" Margin="0,0,10,0" Foreground="{StaticResource AccentLightBrush}"/>
                                <TextBlock Text="Standing Timer" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Sit" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding StandingViewModel.SittingMinutes, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource InputTextBox}" Width="70"/>
                                <TextBlock Text="min" VerticalAlignment="Center" FontSize="11" Margin="6,0,24,0" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="Stand" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding StandingViewModel.StandingMinutes, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource InputTextBox}" Width="70"/>
                                <TextBlock Text="min" VerticalAlignment="Center" FontSize="11" Margin="6,0,0,0" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Start" Style="{StaticResource PrimaryButton}" Padding="20,8"
                                        Command="{Binding StandingViewModel.StartTimersCommand}"
                                        IsEnabled="{Binding StandingViewModel.IsStartButtonEnabled}" Margin="0,0,8,0"/>
                                <Button Content="Stop" Style="{StaticResource SecondaryButton}" Padding="20,8"
                                        Command="{Binding StandingViewModel.StopTimersCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Opacity="0.3" Margin="0,8"/>
                        
                        <!-- Shutdown Timer - Full Width -->
                        <Grid Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⏻" FontSize="16" Margin="0,0,10,0" Foreground="{StaticResource AccentLightBrush}"/>
                                <TextBlock Text="Shutdown Timer" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Date" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ComputerViewModel.SelectedDateText, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource InputTextBox}" Width="120"/>
                                <TextBlock Text="Time" VerticalAlignment="Center" FontSize="12" Margin="16,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ComputerViewModel.SelectedTime}" 
                                         Style="{StaticResource InputTextBox}" Width="80"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Schedule" Style="{StaticResource PrimaryButton}" Padding="20,8"
                                        Command="{Binding ComputerViewModel.ScheduleShutdownCommand}" Margin="0,0,8,0"/>
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Padding="20,8"
                                        Command="{Binding ComputerViewModel.CancelShutdownCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Opacity="0.3" Margin="0,8"/>
                        
                        <!-- File Manager - Full Width -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📁" FontSize="16" Margin="0,0,10,0" Foreground="{StaticResource AccentLightBrush}"/>
                                <TextBlock Text="File Manager" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Grid Grid.Column="1" Margin="32,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MoveFilesViewModel.SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBox}"/>
                                <Button Grid.Column="1" Content="..." Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="8,0"
                                        Command="{Binding MoveFilesViewModel.BrowseSourceCommand}"/>
                                <TextBlock Grid.Column="2" Text="▶" FontSize="12" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource AccentBrush}"/>
                                <TextBox Grid.Column="3" Text="{Binding MoveFilesViewModel.TargetLocation, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBox}"/>
                                <Button Grid.Column="4" Content="..." Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="8,0,0,0"
                                        Command="{Binding MoveFilesViewModel.BrowseTargetCommand}"/>
                            </Grid>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <CheckBox Content="Copy" IsChecked="{Binding MoveFilesViewModel.IsCopy}"
                                          Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Move" Style="{StaticResource PrimaryButton}" Padding="24,8"
                                        Command="{Binding MoveFilesViewModel.MoveFilesCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <!-- AUTOMATION SECTION -->
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <ToggleButton x:Name="AutoToggle" IsChecked="True" Style="{StaticResource SectionToggle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="Auto Clicker" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Background="{Binding AutoClickerViewModel.IsRunning, Converter={StaticResource BoolToRunningBrushConverter}}"
                                    CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AutoClickerViewModel.IsRunning, Converter={StaticResource BoolToRunningTextConverter}}"
                                           FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Grid Visibility="{Binding IsChecked, ElementName=AutoToggle, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Inputs -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="X" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding AutoClickerViewModel.ClickX, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}" Width="100"/>
                            <TextBlock Text="Y" FontSize="12" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding AutoClickerViewModel.ClickY, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}" Width="70"/>
                            <TextBlock Text="Interval" FontSize="12" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding AutoClickerViewModel.IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}" Width="60"/>
                            <TextBlock Text="sec" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        
                        <!-- Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Start" Style="{StaticResource PrimaryButton}" Padding="20,8"
                                    Command="{Binding AutoClickerViewModel.StartCommand}"
                                    IsEnabled="{Binding AutoClickerViewModel.IsRunning, Converter={StaticResource InverseBoolConverter}}" Margin="0,0,8,0"/>
                            <Button Content="Stop" Style="{StaticResource SecondaryButton}" Padding="20,8"
                                    Command="{Binding AutoClickerViewModel.StopCommand}"
                                    IsEnabled="{Binding AutoClickerViewModel.IsRunning}" Margin="0,0,16,0"/>
                            <Button Content="Set Pos" Style="{StaticResource SecondaryButton}" Padding="12,8" ToolTip="Ctrl+P"
                                    Command="{Binding AutoClickerViewModel.GetCurrentPositionCommand}" Margin="0,0,8,0"/>
                            <Button Content="3s Delay" Style="{StaticResource SecondaryButton}" Padding="12,8" ToolTip="Capture in 3 seconds"
                                    Command="{Binding AutoClickerViewModel.CapturePositionCommand}"
                                    IsEnabled="{Binding AutoClickerViewModel.IsCapturingPosition, Converter={StaticResource InverseBoolConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <!-- CLIPBOARD SECTION -->
            <!-- ══════════════════════════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="ClipToggle" IsChecked="True" Style="{StaticResource SectionToggle}" Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                                <TextBlock Text="Clipboard History" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="{Binding ClipboardViewModel.IsMonitoring, Converter={StaticResource BoolToMonitoringTextConverter}}"
                                    Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"
                                    Command="{Binding ClipboardViewModel.ToggleMonitoringCommand}"/>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10" Margin="4,0,0,0"
                                    Command="{Binding ClipboardViewModel.ClearHistoryCommand}"/>
                        </StackPanel>
                    </Grid>
                    
                    <Border Visibility="{Binding IsChecked, ElementName=ClipToggle, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{StaticResource CardInnerBrush}" CornerRadius="6" Padding="4" Margin="0,10,0,0" MaxHeight="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ClipboardViewModel.ClipboardHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="Item" Background="{StaticResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6" Margin="2"
                                                BorderBrush="{Binding IsPinned, Converter={StaticResource BoolToPinBorderConverter}}" BorderThickness="1" Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis" FontSize="11" 
                                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                                                    <TextBlock FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" HorizontalAlignment="Left">
                                                        <Run Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}', Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding Content.Length, StringFormat='{}{0} chars', Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button ToolTip="Pin" Background="Transparent" BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                            Command="{Binding DataContext.ClipboardViewModel.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="📌" FontSize="11" Foreground="{StaticResource AccentLightBrush}"/>
                                                    </Button>
                                                    <Button ToolTip="Copy" Background="Transparent" BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                            Command="{Binding DataContext.ClipboardViewModel.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="📄" FontSize="11" Foreground="{StaticResource AccentLightBrush}"/>
                                                    </Button>
                                                    <Button ToolTip="Delete" Background="Transparent" BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                            Command="{Binding DataContext.ClipboardViewModel.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="🗑️" FontSize="11" Foreground="{StaticResource ErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Item" Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                                            </Trigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
