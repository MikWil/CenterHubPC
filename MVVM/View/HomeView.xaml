<UserControl x:Class="CenterHubNew.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:HomeViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1400"
             Background="Transparent"
             FontFamily="pack://application:,,,/Fonts/Quicksand-VariableFont_wght.ttf#Quicksand"
             SnapsToDevicePixels="True"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextFormattingMode="Ideal">
    
    <UserControl.Resources>
        <!-- Modern Dark Mode Color Palette - Deep Blue/Teal Theme -->
        <Color x:Key="CardBackground">#1A1F2E</Color>
        <Color x:Key="CardBackgroundHover">#232938</Color>
        <Color x:Key="AccentColor">#00D4FF</Color>
        <Color x:Key="AccentColorHover">#33DDFF</Color>
        <Color x:Key="AccentSecondary">#0066FF</Color>
        <Color x:Key="BadgeColor">#2A3441</Color>
        <Color x:Key="TextColor">#E8F4F8</Color>
        <Color x:Key="TextSecondary">#A0B4C8</Color>
        <Color x:Key="SuccessColor">#00E676</Color>
        <Color x:Key="WarningColor">#FFB74D</Color>
        <Color x:Key="ErrorColor">#FF5252</Color>
        <Color x:Key="BorderColor">#2A3441</Color>
        
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
        <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="{StaticResource CardBackgroundHover}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentColorHover}"/>
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}"/>
        <SolidColorBrush x:Key="BadgeBrush" Color="{StaticResource BadgeColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        
        <!-- Modern Card Style with Glassmorphism and Animations -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                              To="#232938" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.02" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.02" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               To="0.5" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                              To="#1A1F2E" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               To="0.3" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Modern Button Style with Animations -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                              To="#33DDFF" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.05" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.05" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                              To="#00D4FF" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2A3441"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#3A4451"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A3441"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#3A4451"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Name="ContentSite"
                                                IsHitTestVisible="False"
                                                Content="{TemplateBinding SelectionBoxItem}"
                                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                Margin="{TemplateBinding Padding}"
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                HorizontalAlignment="Left">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <TextBox Name="PART_EditableTextBox"
                                       Style="{x:Null}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       Focusable="True"
                                       Background="Transparent"
                                       Foreground="{TemplateBinding Foreground}"
                                       BorderThickness="0"
                                       Visibility="Hidden"
                                       IsReadOnly="{TemplateBinding IsReadOnly}"/>
                                <ToggleButton Name="ToggleButton"
                                            Grid.Column="1"
                                            Focusable="False"
                                            ClickMode="Press"
                                            IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                            Width="32">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="8,0">
                                                <Path x:Name="Arrow"
                                                      Fill="{StaticResource TextSecondaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup Name="Popup"
                                     Placement="Bottom"
                                     IsOpen="{TemplateBinding IsDropDownOpen}"
                                     AllowsTransparency="True"
                                     Focusable="False"
                                     PopupAnimation="Slide">
                                    <Grid Name="DropDown"
                                          SnapsToDevicePixels="True"
                                          MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border x:Name="DropDownBorder"
                                              Background="#2A3441"
                                              BorderThickness="1"
                                              BorderBrush="#3A4451"
                                              CornerRadius="8"
                                              Margin="0,4,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                            </Border.Effect>
                                            <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#2A3441"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>
        
        <!-- Badge Style -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource BadgeBrush}"/>
        </Style>
        
        <!-- Accent Badge Style - Better contrast for teal background -->
        <Style x:Key="AccentBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>
        
        <!-- Accent Badge Text Style - Dark text on teal for readability -->
        <Style x:Key="AccentBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#001122"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <!-- Progress Bar Style -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#2A3441"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Grid>
                                <Border x:Name="PART_Track" CornerRadius="5"/>
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="5"
                                        HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Converters -->
        <local:TempToDisplayConverter x:Key="TempToDisplayConverter" />
        <local:VramToDisplayConverter x:Key="VramToDisplayConverter" />
        
        <!-- Text Styles -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>
    
    <!-- Main Scrollable Container -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24"
                  Background="Transparent">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track Name="PART_Track" IsDirectionReversed="true">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Style>
                                                <Style TargetType="Thumb">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="#00D4FF" 
                                                                        CornerRadius="5"
                                                                        Opacity="0.4"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Thumb.Style>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ScrollViewer.Resources>
        
        <Grid x:Name="MainContent" Opacity="0">
            <Grid.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="MainContent"
                                           Storyboard.TargetProperty="Opacity"
                                           From="0" To="1" Duration="0:0:0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            
            <Grid.RowDefinitions>
                <!-- System Metrics Row -->
                <RowDefinition Height="Auto"/>
                <!-- Sound Profiles Row -->
                <RowDefinition Height="Auto"/>
                <!-- Sound Controls Row -->
                <RowDefinition Height="Auto"/>
                <!-- Tools Row 1: Standing Timer & File Manager -->
                <RowDefinition Height="Auto"/>
                <!-- Tools Row 2: Computer Control -->
                <RowDefinition Height="Auto"/>
                <!-- Spacer Row for better separation -->
                <RowDefinition Height="Auto"/>
                <!-- Disk Space Row -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- System Metrics Section -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- CPU Card -->
                <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🖥️" FontSize="24" Margin="0,0,12,0"/>
                            <TextBlock Text="CPU" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}" 
                                       FontSize="42" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Border Style="{StaticResource BadgeStyle}">
                                    <TextBlock Text="{Binding CpuTemperature, Converter={StaticResource TempToDisplayConverter}}" 
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </Border>
                                <Border Style="{StaticResource AccentBadgeStyle}">
                                    <TextBlock Text="{Binding CpuMaxTemperature, Converter={StaticResource TempToDisplayConverter}, ConverterParameter=Max}" 
                                               Style="{StaticResource AccentBadgeTextStyle}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        
                        <ProgressBar Grid.Row="2" Value="{Binding CpuUsage}" Maximum="100"/>
                    </Grid>
                </Border>
                
                <!-- GPU Card -->
                <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🎮" FontSize="24" Margin="0,0,12,0"/>
                            <TextBlock Text="GPU" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GpuUsage, StringFormat='{}{0:F1}%'}" 
                                       FontSize="42" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Border Style="{StaticResource BadgeStyle}">
                                    <TextBlock Text="{Binding GpuTemperature, Converter={StaticResource TempToDisplayConverter}}" 
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </Border>
                                <Border Style="{StaticResource AccentBadgeStyle}">
                                    <TextBlock Text="{Binding GpuMaxTemperature, Converter={StaticResource TempToDisplayConverter}, ConverterParameter=Max}" 
                                               Style="{StaticResource AccentBadgeTextStyle}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        
                        <ProgressBar Grid.Row="2" Value="{Binding GpuUsage}" Maximum="100"/>
                    </Grid>
                </Border>
                
                <!-- Memory Card -->
                <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="💾" FontSize="24" Margin="0,0,12,0"/>
                            <TextBlock Text="Memory" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MemoryUsagePercent, StringFormat='{}{0:F1}%'}" 
                                       FontSize="42" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="{Binding UsedMemory, StringFormat='{}{0:F1} GB Used'}" 
                                       FontSize="14" 
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalMemory, StringFormat='of {0:F1} GB Total'}" 
                                       FontSize="12" 
                                       HorizontalAlignment="Center"
                                       Opacity="0.7"/>
                        </StackPanel>
                        
                        <ProgressBar Grid.Row="2" Value="{Binding MemoryUsagePercent}" Maximum="100"/>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Sound Profiles Section -->
            <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🎵" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Sound Profiles" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="Save current settings to a profile or apply a saved profile" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Profile 1 -->
                        <Border Grid.Column="0" Background="#2A3441" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBox Text="{Binding SoundViewModel.Profile1.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile1.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile1.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile1.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding SoundViewModel.ApplyProfileCommand}" 
                                        CommandParameter="0"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Margin="0,4,0,4"
                                        Padding="12,6"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" 
                                        CommandParameter="0"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Background="#3A4451"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 2 -->
                        <Border Grid.Column="1" Background="#2A3441" CornerRadius="12" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBox Text="{Binding SoundViewModel.Profile2.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile2.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile2.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile2.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding SoundViewModel.ApplyProfileCommand}" 
                                        CommandParameter="1"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Margin="0,4,0,4"
                                        Padding="12,6"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" 
                                        CommandParameter="1"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Background="#3A4451"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 3 -->
                        <Border Grid.Column="2" Background="#2A3441" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBox Text="{Binding SoundViewModel.Profile3.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile3.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile3.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SoundViewModel.Profile3.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding SoundViewModel.ApplyProfileCommand}" 
                                        CommandParameter="2"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Margin="0,4,0,4"
                                        Padding="12,6"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SoundViewModel.SaveCurrentProfileCommand}" 
                                        CommandParameter="2"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="32" 
                                        FontSize="12"
                                        Background="#3A4451"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Sound Controls Section -->
            <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Microphone -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🎤" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Microphone" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <Button Content="{Binding SoundViewModel.MicrophoneMuteButtonText}" 
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding SoundViewModel.ToggleMicrophoneMuteCommand}"
                                MinWidth="160"/>
                    </StackPanel>
                    
                    <!-- Volume Control -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="24,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🔊" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Volume" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔇" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>
                            <Slider Minimum="0" Maximum="1" 
                                    Value="{Binding SoundViewModel.OutputVolume, Mode=TwoWay}" 
                                    Width="140" 
                                    Height="24"
                                    VerticalAlignment="Center"
                                    Grid.Column="1"/>
                            <TextBlock Text="{Binding SoundViewModel.OutputVolume, StringFormat='{}{0:P0}'}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center" 
                                       Margin="12,0,0,0"
                                       MinWidth="40"
                                       Grid.Column="2"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Output Device -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🔊" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Output Device" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding SoundViewModel.ActiveSoundSource}"
                                  SelectedItem="{Binding SoundViewModel.SelectedSoundSource}"
                                  MinWidth="200"
                                  Margin="0,0,0,12"
                                  Style="{StaticResource ModernComboBoxStyle}"/>
                        <Button Content="Set Active" 
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding SoundViewModel.SetActiveOutputDeviceCommand}"
                                MinWidth="120"
                                Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Tools Row 1: Standing Timer & File Manager -->
            <Grid Grid.Row="3" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Standing Timer Card -->
                <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="🧍" FontSize="22" Margin="0,0,12,0"/>
                            <TextBlock Text="Standing Timer" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Sitting:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Text="{Binding StandingViewModel.SittingMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Standing:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,12,0"/>
                            <TextBox Text="{Binding StandingViewModel.StandingMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Start" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding StandingViewModel.StartTimersCommand}"
                                    IsEnabled="{Binding StandingViewModel.IsStartButtonEnabled}"
                                    Margin="0,0,12,0"
                                    MinWidth="100"/>
                        <Button Content="Stop" 
                                Background="#3A4451"
                                Foreground="White"
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding StandingViewModel.StopTimersCommand}"
                                MinWidth="100"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- File Manager Card -->
                <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="📁" FontSize="22" Margin="0,0,12,0"/>
                            <TextBlock Text="File Manager" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <TextBlock Text="Source Location:" Margin="0,0,0,8"/>
                        <DockPanel LastChildFill="True" Margin="0,0,0,16">
                            <Button Content="Browse" 
                                    DockPanel.Dock="Right"
                                    Margin="12,0,0,0"
                                    MinWidth="100"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding MoveFilesViewModel.BrowseSourceCommand}"/>
                            <TextBox Text="{Binding MoveFilesViewModel.SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </DockPanel>
                        
                        <TextBlock Text="Target Location:" Margin="0,0,0,8"/>
                        <DockPanel LastChildFill="True" Margin="0,0,0,16">
                            <Button Content="Browse" 
                                    DockPanel.Dock="Right"
                                    Margin="12,0,0,0"
                                    MinWidth="100"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding MoveFilesViewModel.BrowseTargetCommand}"/>
                            <TextBox Text="{Binding MoveFilesViewModel.TargetLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </DockPanel>
                        
                        <CheckBox Content="Copy instead of move" 
                                  IsChecked="{Binding MoveFilesViewModel.IsCopy}"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,16"/>
                        
                        <Button Content="Execute" 
                                Style="{StaticResource ModernButtonStyle}"
                                Command="{Binding MoveFilesViewModel.MoveFilesCommand}"
                                HorizontalAlignment="Left"
                                MinWidth="140"/>
                        
                        <TextBlock Text="{Binding MoveFilesViewModel.StatusMessage}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Computer Control - Full Width -->
            <Border Grid.Row="4" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <TextBlock Text="💻" FontSize="22" Margin="0,0,12,0"/>
                        <TextBlock Text="Computer Control" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Date/Time Input Section -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Shutdown at:" 
                                     VerticalAlignment="Center" 
                                     Margin="0,0,16,0"
                                     FontSize="14"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border Background="#2A3441"
                                    BorderBrush="#3A4451"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="0"
                                    Width="160"
                                    Height="40"
                                    Margin="0,0,12,0">
                                <DatePicker SelectedDate="{Binding ComputerViewModel.SelectedDate, Mode=TwoWay}" 
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Height="40"
                                            VerticalContentAlignment="Center">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="12,10"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Border>
                            <Border Background="#2A3441"
                                    BorderBrush="#3A4451"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="0"
                                    Width="100"
                                    Height="40"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ComputerViewModel.SelectedTime, Mode=TwoWay}" 
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="12,10"
                                             FontSize="14"
                                             VerticalContentAlignment="Center"
                                             VerticalAlignment="Center"
                                             Grid.Column="0"/>
                                    <TextBlock Text="🕐" 
                                               FontSize="14" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,12,0"
                                               Opacity="0.6"
                                               Grid.Column="1"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                        
                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Schedule Shutdown" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding ComputerViewModel.ScheduleShutdownCommand}"
                                    Margin="0,0,12,0"
                                    MinWidth="180"
                                    Height="40"/>
                            <Button Content="Cancel Shutdown" 
                                    Background="#3A4451"
                                    Foreground="White"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Command="{Binding ComputerViewModel.CancelShutdownCommand}"
                                    MinWidth="180"
                                    Height="40"/>
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock Text="{Binding ComputerViewModel.StatusMessage}"
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               MinHeight="20"/>
                </StackPanel>
            </Border>
            
            <!-- Spacer for better separation -->
            <Border Grid.Row="5" Height="32" Background="Transparent"/>
            
            <!-- Disk Space Section -->
            <Border Grid.Row="6" Style="{StaticResource ModernCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="💿" FontSize="22" Margin="0,0,12,0"/>
                        <TextBlock Text="Disk Space" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A3441" 
                                            CornerRadius="12" 
                                            Padding="16" 
                                            Margin="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DriveLetter}" 
                                                       FontWeight="Bold" 
                                                       FontSize="16" 
                                                       Margin="0,0,0,8" 
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Text="{Binding UsedSpace, StringFormat='{}{0:F1} GB'}" 
                                                       FontSize="14" 
                                                       Margin="0,2" 
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalSize, StringFormat='of {0:F1} GB'}" 
                                                       Opacity="0.7" 
                                                       FontSize="12" 
                                                       Margin="0,2" 
                                                       HorizontalAlignment="Center"/>
                                            <ProgressBar Value="{Binding UsedSpace}" 
                                                         Maximum="{Binding TotalSize}" 
                                                         Height="8" 
                                                         Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
