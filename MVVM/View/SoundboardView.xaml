<UserControl x:Class="CenterHubNew.MVVM.View.SoundboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:SoundboardViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🔊" FontSize="22" Margin="0,0,10,0" Foreground="{StaticResource AccentLightBrush}"/>
            <TextBlock Text="Soundboard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>
        
        <!-- Controls Bar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Add/Stop Buttons -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <Button Content="+ Add Sound" Style="{StaticResource PrimaryButton}" Padding="16,10"
                            Command="{Binding AddSoundCommand}" Margin="0,0,8,0"/>
                    <Button Content="⏹ Stop" Style="{StaticResource SecondaryButton}" Padding="16,10"
                            Command="{Binding StopSoundCommand}"/>
                </StackPanel>
                
                <!-- Output Device Selection -->
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Output:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding OutputDevices}" 
                              SelectedItem="{Binding SelectedOutputDevice}"
                              Style="{StaticResource DropdownStyle}" Width="160"/>
                    <Slider Minimum="0" Maximum="1" Width="80" 
                            Value="{Binding OutputVolume}" VerticalAlignment="Center" Margin="8,0,0,0"
                            ToolTip="Output Volume"/>
                    <TextBlock Text="{Binding OutputVolume, StringFormat='{}{0:P0}'}" FontSize="11" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="35"/>
                    <Button Content="↻" Style="{StaticResource SecondaryButton}" Padding="8,6" Margin="6,0,0,0"
                            Command="{Binding RefreshDevicesCommand}" ToolTip="Refresh devices"/>
                    <Button Content="?" Style="{StaticResource SecondaryButton}" Padding="8,6" Margin="6,0,0,0"
                            Click="HelpBtn_Click" ToolTip="Discord Setup Help" FontWeight="Bold"/>
                </StackPanel>
                
                <!-- Monitor Controls (Row 2) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <CheckBox IsChecked="{Binding MonitorEnabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Monitor (hear yourself):" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding OutputDevices}" 
                              SelectedItem="{Binding SelectedMonitorDevice}"
                              Style="{StaticResource DropdownStyle}" Width="180"
                              IsEnabled="{Binding MonitorEnabled}"/>
                    <TextBlock Text="Volume:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <Slider Minimum="0" Maximum="1" Width="100" 
                            Value="{Binding MonitorVolume}" VerticalAlignment="Center"
                            IsEnabled="{Binding MonitorEnabled}"/>
                    <TextBlock Text="{Binding MonitorVolume, StringFormat='{}{0:P0}'}" FontSize="11" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="35"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Sound Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Sounds.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="No sounds yet" FontSize="16" HorizontalAlignment="Center" 
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,0"/>
                    <TextBlock Text="Click '+ Add Sound' to get started" FontSize="12" HorizontalAlignment="Center" 
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Sounds Grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewer}">
                    <ItemsControl ItemsSource="{Binding Sounds}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SoundButton" Width="140" Height="100" Margin="6" 
                                        CornerRadius="10" Cursor="Hand"
                                        Background="{StaticResource CardInnerBrush}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Play Icon -->
                                        <TextBlock Grid.Row="0" Text="▶" FontSize="28" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        
                                        <!-- Sound Name & Controls -->
                                        <Border Grid.Row="1" Background="#20000000" Padding="8,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" 
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" ToolTip="Remove" Background="Transparent" BorderThickness="0"
                                                        Padding="4,2" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveSoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="✕" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Volume Indicator -->
                                        <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Background="#40000000" CornerRadius="0,10,0,6" Padding="6,3">
                                            <TextBlock Text="{Binding Volume, StringFormat='{}{0:P0}'}" FontSize="9" 
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="SoundButton" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Discord Help Panel -->
        <Border x:Name="HelpPanel" Grid.RowSpan="3" Background="#90000000" Visibility="Collapsed">
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="28"
                    Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="🎮 Discord Setup Guide" FontSize="20" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="16" Cursor="Hand"
                                Click="CloseHelpBtn_Click"/>
                    </Grid>
                    
                    <TextBlock Text="To let your Discord friends hear your soundboard:" FontSize="13" 
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                    
                    <Border Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Step 1: Install Voicemeeter" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                Download and install <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Voicemeeter Banana</Run> (free) from vb-audio.com
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Step 2: Configure Voicemeeter" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                • Set your real microphone as <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Hardware Input 1</Run><LineBreak/>
                                • Your voice will mix with the soundboard automatically
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Step 3: Soundboard Output" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                In this app, select <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Voicemeeter VAIO Input</Run> or <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Voicemeeter AUX Input</Run> as Output Device
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Step 4: Discord Settings" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                In Discord → Settings → Voice &amp; Video:<LineBreak/>
                                Set Input Device to <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Voicemeeter Output (VB-Audio)</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="12" Opacity="0.9">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextOnAccentBrush}" TextAlignment="Center">
                            <Run FontWeight="SemiBold">Result:</Run> Your voice + soundboard sounds will both be heard in Discord! 🎉
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- Edit Sound Popup -->
        <Border Grid.RowSpan="3" Background="#80000000" 
                Visibility="{Binding SelectedSound, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="24"
                    Width="400" Height="Auto" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Edit Sound" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SelectedSound.Name, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="File Path" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SelectedSound.FilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="8,0,0,0"
                                Command="{Binding BrowseSoundFileCommand}"/>
                    </Grid>
                    
                    <TextBlock Text="Volume" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="0" Maximum="1" 
                                Value="{Binding SelectedSound.Volume, Mode=TwoWay}" 
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding SelectedSound.Volume, StringFormat='{}{0:P0}'}"
                                   FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" 
                                   VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="40"/>
                    </Grid>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Padding="20,10" Margin="0,0,8,0"
                                Command="{Binding CancelSoundEditCommand}"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButton}" Padding="20,10"
                                Command="{Binding SaveSoundEditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>

