<UserControl x:Class="CenterHubNew.MVVM.View.SoundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodel ="clr-namespace:CenterHubNew.MVVM.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:SoundViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#232136">
    <UserControl.Resources>
        <Color x:Key="AccentColor">#7F5AF0</Color>
        <Color x:Key="CardBackground">#272537</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
        <local:BoolToMuteTextConverter x:Key="BoolToMuteTextConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="18" Padding="32" Margin="40,32,40,32">
            <Border.Effect>
                <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="1" Opacity="0.18"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="700">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,18">
                        <TextBlock Text="🔊" FontSize="22" Margin="0,0,8,0"/>
                        <TextBlock Text="Sound Controls" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <!-- Sound Profiles Section -->
                    <TextBlock Text="Sound Profiles" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Text="Save current settings to a profile or apply a saved profile" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Profile 1 -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#2A2A3A" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile1.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="White"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile1.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile1.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile1.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding ApplyProfileCommand}" 
                                        CommandParameter="0"
                                        Height="28" 
                                        FontSize="12"
                                        Margin="0,4,0,4"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SaveCurrentProfileCommand}" 
                                        CommandParameter="0"
                                        Height="28" 
                                        FontSize="12"
                                        Background="#4A4A5A"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 2 -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#2A2A3A" CornerRadius="12" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile2.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="White"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile2.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile2.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile2.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding ApplyProfileCommand}" 
                                        CommandParameter="1"
                                        Height="28" 
                                        FontSize="12"
                                        Margin="0,4,0,4"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SaveCurrentProfileCommand}" 
                                        CommandParameter="1"
                                        Height="28" 
                                        FontSize="12"
                                        Background="#4A4A5A"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 3 -->
                        <Border Grid.Row="0" Grid.Column="2" Background="#2A2A3A" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile3.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" FontWeight="Bold" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="White"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Comm Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile3.CommunicationDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Audio Device:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile3.AudioDevice, TargetNullValue='Not set'}" 
                                           FontSize="12" 
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Volume:" FontSize="11" Foreground="#A0A0A0" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Profile3.Volume, StringFormat='{}{0:P0}'}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="Apply" 
                                        Command="{Binding ApplyProfileCommand}" 
                                        CommandParameter="2"
                                        Height="28" 
                                        FontSize="12"
                                        Margin="0,4,0,4"/>
                                <Button Content="Save Current" 
                                        Command="{Binding SaveCurrentProfileCommand}" 
                                        CommandParameter="2"
                                        Height="28" 
                                        FontSize="12"
                                        Background="#4A4A5A"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Separator -->
                    <Border Height="1" Background="#3A3A4A" Margin="0,8,0,24"/>
                    
                    <!-- Current Settings Section -->
                    <TextBlock Text="Current Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Text="Current Output Device:" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ActiveSoundSource}"
                              SelectedItem="{Binding SelectedSoundSource}"
                              />
                    <TextBlock Text="Set as default:" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button Content="Audio" Height ="25" MinWidth="120" Margin="0,0,12,0" Command="{Binding SetDefaultPlaybackDeviceCommand}"/>
                        <Button Content="Communication" Height ="25" MinWidth="120" Margin="0,0,12,0" Command="{Binding SetDefaultCommunicationDeviceCommand}"/>
                    </StackPanel>
                    <TextBlock Text="Volume:" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔇" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" Grid.Column="0"/>
                        <Slider Minimum="0" Maximum="1" 
                                Value="{Binding OutputVolume, Mode=TwoWay}" 
                                Width="200" 
                                Height="24"
                                VerticalAlignment="Center"
                                Grid.Column="1"/>
                        <TextBlock Text="{Binding OutputVolume, StringFormat='{}{0:P0}'}" 
                                   FontSize="14" 
                                   VerticalAlignment="Center" 
                                   Margin="12,0,0,0"
                                   MinWidth="40"
                                   Grid.Column="2"/>
                    </Grid>
                    <TextBlock Text="Microphone:" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,4"/>
                    <Button Content="{Binding MicrophoneMuteButtonText}" 
                            Height="32" 
                            Command="{Binding ToggleMicrophoneMuteCommand}"
                            Margin="0,8,0,0"/>
                    <Button Content="Open Advanced Sound Controls" Margin="0,24,0,0" Height="32" Click="OpenSoundControlsWindow_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
