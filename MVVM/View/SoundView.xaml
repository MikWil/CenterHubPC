<UserControl x:Class="CenterHubNew.MVVM.View.SoundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:SoundViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <local:BoolToMuteTextConverter x:Key="BoolToMuteTextConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="20,16" Background="Transparent">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="🎵" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                <TextBlock Text="Sound" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            
            <!-- Profiles -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="PROFILES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Profile 1 -->
                        <Border Grid.Column="0" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile1.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                         Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Profile1.AudioDevice, TargetNullValue='No device'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Profile1.Volume, StringFormat='Vol: {0:P0}'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Apply" Command="{Binding ApplyProfileCommand}" CommandParameter="0"
                                            Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" CommandParameter="0"
                                            Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 2 -->
                        <Border Grid.Column="1" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="12" Margin="3,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile2.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                         Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Profile2.AudioDevice, TargetNullValue='No device'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Profile2.Volume, StringFormat='Vol: {0:P0}'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Apply" Command="{Binding ApplyProfileCommand}" CommandParameter="1"
                                            Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" CommandParameter="1"
                                            Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Profile 3 -->
                        <Border Grid.Column="2" Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBox Text="{Binding Profile3.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="12" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" 
                                         Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" Padding="0" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Profile3.AudioDevice, TargetNullValue='No device'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Profile3.Volume, StringFormat='Vol: {0:P0}'}" 
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Apply" Command="{Binding ApplyProfileCommand}" CommandParameter="2"
                                            Style="{StaticResource PrimaryButton}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                    <Button Content="Save" Command="{Binding SaveCurrentProfileCommand}" CommandParameter="2"
                                            Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Quick Controls -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="QUICK CONTROLS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Mic -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🎤" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                            <Button Content="{Binding MicrophoneMuteButtonText}" 
                                    Command="{Binding ToggleMicrophoneMuteCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                        </StackPanel>
                        
                        <!-- Volume -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource AccentLightBrush}"/>
                            <Slider Minimum="0" Maximum="1" Value="{Binding OutputVolume, Mode=TwoWay}" 
                                    Width="120" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OutputVolume, StringFormat='{}{0:P0}'}" 
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="35" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <!-- Output -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding ActiveSoundSource}"
                                      SelectedItem="{Binding SelectedSoundSource}"
                                      Width="180" Style="{StaticResource DropdownStyle}"/>
                            <Button Content="Audio" Style="{StaticResource PrimaryButton}" Padding="10,6" Margin="6,0,0,0"
                                    Command="{Binding SetDefaultPlaybackDeviceCommand}"/>
                            <Button Content="Comm" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="4,0,0,0"
                                    Command="{Binding SetDefaultCommunicationDeviceCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Advanced -->
            <Border Style="{StaticResource CardStyle}">
                <Button Content="Open Advanced Sound Controls" 
                        Style="{StaticResource SecondaryButton}" Padding="16,8"
                        HorizontalAlignment="Left"
                        Click="OpenSoundControlsWindow_Click"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
