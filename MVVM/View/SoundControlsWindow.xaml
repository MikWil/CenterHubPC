<Window x:Class="CenterHubNew.MVVM.View.SoundControlsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
        Title="Sound Controls" Height="520" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <local:ProgressToWidthConverter x:Key="ProgressToWidthConverter" />
            <Color x:Key="CardBackground">#272537</Color>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
            <SolidColorBrush x:Key="TextBrush" Color="#F5F5F5"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/Quicksand-VariableFont_wght.ttf#Quicksand"/>
            </Style>
            <!-- Modern Pill Button Style for Mute -->
            <Style x:Key="MuteButtonStyle" TargetType="Button">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="MinWidth" Value="64"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="8,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryHueDarkBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <local:BoolToMuteTextConverter x:Key="BoolToMuteText" />
        </ResourceDictionary>
    </Window.Resources>
    <Border Background="#232136" CornerRadius="18" Padding="0" Margin="18">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="2" Opacity="0.22"/>
        </Border.Effect>
        <Grid>
            <!-- Custom Move Bar -->
            <Grid Height="48" Background="#1A1826" VerticalAlignment="Top" MouseDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="🔊" FontSize="22" Margin="0,0,10,0"/>
                    <TextBlock Text="App Sound Controls" FontWeight="Bold" FontSize="18"/>
                </StackPanel>
                <Button Content="✕" Width="36" Height="36" Grid.Column="1" Margin="0,6,12,6" VerticalAlignment="Center" HorizontalAlignment="Right" Click="CloseButton_Click" Background="#7F5AF0" Foreground="White" BorderThickness="0" FontSize="18"/>
            </Grid>
            <!-- Main Content -->
            <ScrollViewer Margin="0,48,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,18">
                                <!-- Device Name and Main Controls -->
                                <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" Foreground="White" FontSize="16" Margin="8,8,8,2"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="pack://application:,,,/Images/volume_icon.png" Width="24" Height="24" VerticalAlignment="Center" Grid.Column="0" Cursor="Hand"/>
                                    <Slider Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" Grid.Column="1" Height="20" />
                                    <TextBlock Text="{Binding Volume, StringFormat={}{0:P0}}" Foreground="White" FontSize="15" Margin="8,0,0,0" Width="40" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="2"/>
                                </Grid>
                                <Separator Margin="0,0,0,4"/>
                                <!-- Per-App Controls -->
                                <ItemsControl ItemsSource="{Binding Sessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Margin="0,0,4,0" Foreground="White" VerticalAlignment="Center" FontSize="14" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                                                <Slider Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" Grid.Column="1" />
                                                <TextBlock Text="{Binding Volume, StringFormat={}{0:P0}}"  Foreground="White" FontSize="13" Margin="4,0,0,0" Width="32" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window> 