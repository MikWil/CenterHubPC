<UserControl x:Class="CenterHubNew.MVVM.View.MoveFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             xmlns:viewmodel ="clr-namespace:CenterHubNew.MVVM.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:MoveFilesViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#272537">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Move Files"
                   Foreground="White"
                   FontSize="28"
                   HorizontalAlignment="Left"
                   Margin="20,10,0,0"
                   Grid.ColumnSpan="2"
                   FontFamily="/Fonts/#Poppins"/>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="20,10">
            <TextBlock Text="Source Location:"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,5"
                       FontFamily="/Fonts/#Poppins"/>
            
            <DockPanel LastChildFill="True">
                <Button Content="Browse"
                        DockPanel.Dock="Right"
                        Margin="10,0,0,0"
                        Width="80"
                        Command="{Binding BrowseSourceCommand}"
                        Background="#353340"
                        Foreground="White"/>
                <TextBox Text="{Binding SourceLocation, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         Background="#353340"
                         Foreground="White"
                         Padding="5"
                         BorderThickness="1"
                         BorderBrush="#454545"/>
            </DockPanel>

            <TextBlock Text="Target Location:"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,15,0,5"
                       FontFamily="/Fonts/#Poppins"/>
            
            <DockPanel LastChildFill="True">
                <Button Content="Browse"
                        DockPanel.Dock="Right"
                        Margin="10,0,0,0"
                        Width="80"
                        Command="{Binding BrowseTargetCommand}"
                        Background="#353340"
                        Foreground="White"/>
                <TextBox Text="{Binding TargetLocation, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         Background="#353340"
                         Foreground="White"
                         Padding="5"
                         BorderThickness="1"
                         BorderBrush="#454545"/>
            </DockPanel>

            <CheckBox Content="Copy instead of move"
                      IsChecked="{Binding IsCopy}"
                      Foreground="White"
                      Margin="0,15,0,0"
                      FontFamily="/Fonts/#Poppins"/>

            <Button Content="Execute"
                    Margin="0,20,0,0"
                    Height="40"
                    Width="150"
                    HorizontalAlignment="Left"
                    Command="{Binding MoveFilesCommand}"
                    Background="#007ACC"
                    Foreground="White"
                    FontSize="16"
                    FontFamily="/Fonts/#Poppins"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,15,0,0"
                       TextWrapping="Wrap"
                       FontFamily="/Fonts/#Poppins"/>
        </StackPanel>
    </Grid>
</UserControl>
