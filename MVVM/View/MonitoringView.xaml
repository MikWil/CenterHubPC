<UserControl x:Class="CenterHubNew.MVVM.View.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel" 
             d:DataContext="{d:DesignInstance Type=viewmodel:MonitoringViewModel}"
             xmlns:local="clr-namespace:CenterHubNew.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <local:TempToDisplayConverter x:Key="TempToDisplayConverter" />
        
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource CardInnerBrush}"/>
        </Style>
        
        <Style x:Key="AccentBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>
        
        <Style x:Key="AccentBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <!-- Half-width card (for 2-column layout) -->
        <Style x:Key="HalfCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        
        <!-- Full-width card -->
        <Style x:Key="FullCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardInnerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Grid>
                                <Border x:Name="PART_Track" CornerRadius="3"/>
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <ScrollViewer Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="16" Background="Transparent">
        <StackPanel>
            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="📊" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                <TextBlock Text="Monitoring" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            
            <!-- Row 1: CPU & GPU (half-width each) -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- CPU Card -->
                <Border Grid.Column="0" Style="{StaticResource HalfCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🖥️" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="CPU" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}" 
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                <Border Style="{StaticResource BadgeStyle}">
                                    <TextBlock Text="{Binding CpuTemperature, Converter={StaticResource TempToDisplayConverter}}" 
                                               FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource AccentBadgeStyle}">
                                    <TextBlock Text="{Binding CpuMaxTemperature, Converter={StaticResource TempToDisplayConverter}, ConverterParameter=Max}" 
                                               Style="{StaticResource AccentBadgeTextStyle}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        
                        <ProgressBar Grid.Row="2" Value="{Binding CpuUsage}" Maximum="100"/>
                    </Grid>
                </Border>
                
                <!-- GPU Card -->
                <Border Grid.Column="2" Style="{StaticResource HalfCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🎮" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                            <TextBlock Text="GPU" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="{Binding GpuUsage, StringFormat='{}{0:F1}%'}" 
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                <Border Style="{StaticResource BadgeStyle}">
                                    <TextBlock Text="{Binding GpuTemperature, Converter={StaticResource TempToDisplayConverter}}" 
                                               FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource AccentBadgeStyle}">
                                    <TextBlock Text="{Binding GpuMaxTemperature, Converter={StaticResource TempToDisplayConverter}, ConverterParameter=Max}" 
                                               Style="{StaticResource AccentBadgeTextStyle}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        
                        <ProgressBar Grid.Row="2" Value="{Binding GpuUsage}" Maximum="100"/>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Row 2: Memory (full-width) -->
            <Border Style="{StaticResource FullCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                        <TextBlock Text="Memory" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="24,0">
                        <ProgressBar Value="{Binding MemoryUsagePercent}" Maximum="100" Margin="0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MemoryUsagePercent, StringFormat='{}{0:F1}%'}" 
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UsedMemory, StringFormat='{}{0:F1} GB Used'}" 
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalMemory, StringFormat='of {0:F1} GB'}" 
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Row 3: Disk Space (full-width) -->
            <Border Style="{StaticResource FullCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="💿" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource AccentLightBrush}"/>
                        <TextBlock Text="Disk Space" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardInnerBrush}" CornerRadius="8" Padding="12" Margin="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DriveLetter}" FontWeight="Bold" FontSize="13" 
                                                   HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="{Binding UsedSpace, StringFormat='{}{0:F1} GB'}" 
                                                   FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding TotalSize, StringFormat='of {0:F1} GB'}" 
                                                   FontSize="10" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                        <ProgressBar Value="{Binding UsedSpace}" Maximum="{Binding TotalSize}" Height="4" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
