<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:CenterHubNew.MVVM.ViewModel"
        xmlns:conv="clr-namespace:CenterHubNew.MVVM.Converters"
        x:Class="CenterHubNew.MVVM.View.FavoritesWindow"
        x:DataType="viewmodel:FavoritesViewModel"
        mc:Ignorable="d"
        Title="Favorites"
        Width="380" Height="640"
        MinWidth="320" MinHeight="500"
        SystemDecorations="None"
        TransparencyLevelHint="Mica,AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="Transparent">

    <Window.Resources>
        <conv:TempToDisplayConverter x:Key="TempToDisplay"/>
    </Window.Resources>

    <!-- Outer frame (Mica subtly visible through) -->
    <Border Background="{StaticResource BackgroundDarkBrush}"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{StaticResource BorderHairline}">
        <Grid RowDefinitions="46,*" ClipToBounds="True">

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                  PointerPressed="TitleBar_PointerPressed">
                <Border Grid.ColumnSpan="2"
                        Background="{StaticResource TitleBarBackgroundBrush}"
                        CornerRadius="8,8,0,0"/>

                <!-- App dot + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0" Spacing="8">
                    <Border Width="16" Height="16" CornerRadius="8"
                            Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="{StaticResource TextOnAccentBrush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Favorites" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="1" Classes="chrome"
                        Width="32" Height="32" Margin="0,0,8,0"
                        Click="CloseButton_Click"
                        ToolTip.Tip="Close">
                    <TextBlock Text="&#xD7;" FontSize="15"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,12,12,24">
                <StackPanel Spacing="8" Margin="0,0,0,16">

                    <!-- CPU -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="10" Padding="0"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                            ClipToBounds="True">
                        <StackPanel>
                            <Border Height="2" Background="{StaticResource CpuBrush}"/>
                            <Border Padding="12,10"><Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{StaticResource AccentSubtleBrush}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="CPU" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource CpuBrush}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}"
                                               FontSize="26" FontWeight="Bold"
                                               Foreground="{StaticResource CpuBrush}"/>
                                    <ProgressBar Classes="cpu" Value="{Binding CpuUsage}" Maximum="100"
                                                 Height="4" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="{StaticResource CardInnerBrush}"
                                        CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CpuTemperature, Converter={StaticResource TempToDisplay}}"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </Grid></Border>
                        </StackPanel>
                    </Border>

                    <!-- GPU -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="10" Padding="0"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                            ClipToBounds="True">
                        <StackPanel>
                            <Border Height="2" Background="{StaticResource GpuBrush}"/>
                            <Border Padding="12,10"><Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#22A78BFA"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="GPU" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource GpuBrush}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GpuUsage, StringFormat='{}{0:F1}%'}"
                                               FontSize="26" FontWeight="Bold"
                                               Foreground="{StaticResource GpuBrush}"/>
                                    <ProgressBar Classes="gpu" Value="{Binding GpuUsage}" Maximum="100"
                                                 Height="4" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding GpuName}"
                                               FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="{StaticResource CardInnerBrush}"
                                        CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GpuTemperature, Converter={StaticResource TempToDisplay}}"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </Grid></Border>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="10" Padding="0"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                            ClipToBounds="True">
                        <StackPanel>
                            <Border Height="2" Background="{StaticResource RamBrush}"/>
                            <Border Padding="12,10"><Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#2234D399"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="RAM" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource RamBrush}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MemoryUsagePercent, StringFormat='{}{0:F1}%'}"
                                               FontSize="26" FontWeight="Bold"
                                               Foreground="{StaticResource RamBrush}"/>
                                    <ProgressBar Classes="ram" Value="{Binding MemoryUsagePercent}" Maximum="100"
                                                 Height="4" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UsedMemory, StringFormat='{}{0:F1} GB'}"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding TotalMemory, StringFormat='/ {0:F1} GB'}"
                                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid></Border>
                        </StackPanel>
                    </Border>

                    <!-- AUDIO CONTROLS -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="10" Padding="12,12"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="AUDIO" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{StaticResource TextMutedBrush}"/>

                            <!-- Volume -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="VOL" FontSize="9" FontWeight="Bold" LetterSpacing="0.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                        Value="{Binding Sound.OutputVolume, Mode=TwoWay}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Sound.OutputVolume, StringFormat='{}{0:P0}'}"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" MinWidth="34"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>

                            <!-- Mic toggle -->
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="MIC" FontSize="9" FontWeight="Bold" LetterSpacing="0.5"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="{Binding Sound.MicrophoneMuteButtonText}"
                                        Classes="secondary" Padding="10,6" FontSize="12"
                                        Command="{Binding Sound.ToggleMicrophoneMuteCommand}"
                                        HorizontalAlignment="Left"/>
                            </Grid>

                            <!-- Device -->
                            <ComboBox ItemsSource="{Binding Sound.ActiveSoundSource}"
                                      SelectedItem="{Binding Sound.SelectedSoundSource}"
                                      HorizontalAlignment="Stretch"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Set Audio" Classes="primary" Padding="10,6" FontSize="11"
                                        Command="{Binding Sound.SetDefaultPlaybackDeviceCommand}"/>
                                <Button Content="Set Comm" Classes="secondary" Padding="10,6" FontSize="11"
                                        Command="{Binding Sound.SetDefaultCommunicationDeviceCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SOUND PROFILES quick row -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="10" Padding="12,10"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="SOUND PROFILES" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <Grid ColumnDefinitions="*,6,*,6,*">
                                <Button Grid.Column="0" Classes="secondary" Padding="0,9" FontSize="11"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding Sound.ApplyProfileCommand}" CommandParameter="0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sound.Profile1.Name}" FontSize="11"
                                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Apply" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Classes="secondary" Padding="0,9" FontSize="11"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding Sound.ApplyProfileCommand}" CommandParameter="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sound.Profile2.Name}" FontSize="11"
                                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Apply" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4" Classes="secondary" Padding="0,9" FontSize="11"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding Sound.ApplyProfileCommand}" CommandParameter="2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sound.Profile3.Name}" FontSize="11"
                                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Apply" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
